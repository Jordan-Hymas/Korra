# Korra environment configuration
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real tokens.

# Base URL for OpenClaw on pve1
KORRA_OPENCLAW_URL=http://100.68.10.1:18793

# Dedicated Korra bearer token (set this in OpenClaw's gateway config)
KORRA_OPENCLAW_TOKEN=replace_me

# Picovoice Porcupine access key (get from console.picovoice.ai)
PORCUPINE_ACCESS_KEY=replace_me

# Optional overrides (defaults shown)
# KORRA_MODEL=openai-codex/gpt-5.3-codex
# KORRA_MAX_TOKENS=600
# KORRA_TIMEOUT_SECONDS=30
